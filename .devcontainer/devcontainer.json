{
  "name": "Mars Maps Classroom",

  // Python 3.12 base image — comes with git, curl, pip
  "image": "mcr.microsoft.com/devcontainers/python:3.12",

  // Runs once when the Codespace is first created (not on every start)
  "onCreateCommand": "bash .devcontainer/setup.sh",

  // Runs every time the Codespace starts
  "postStartCommand": "echo '🚀 Mars Maps is ready! Run: python verify_setup.py'",

  "customizations": {
    "vscode": {

      // Extensions auto-installed on first open — students install nothing manually
      "extensions": [
        "RooVeterinaryInc.roo-cline",      // AI coding partner
        "ritwickdey.LiveServer",            // HTML preview in browser
        "RobbOwen.synthwave-vscode",        // Neon theme kids love
        "pomdtr.excalidraw-editor",         // Whiteboard / diagram annotation
        "hediet.vscode-drawio",             // PNG markup
        "ms-python.python",                 // Python language support
        "ms-python.pylance",                // Python autocomplete
        "PKief.material-icon-theme"         // File icons (easier to navigate)
      ],

      "settings": {
        // ── Appearance ────────────────────────────────────────────────────
        "workbench.colorTheme":             "SynthWave '84",
        "workbench.iconTheme":              "material-icon-theme",
        "editor.fontSize":                  18,
        "editor.lineHeight":                1.8,
        "editor.fontFamily":                "'Fira Code', 'Cascadia Code', Consolas, monospace",
        "editor.fontLigatures":             true,
        "terminal.integrated.fontSize":     16,
        "editor.minimap.enabled":           false,

        // ── Editor comfort ────────────────────────────────────────────────
        "editor.wordWrap":                  "on",
        "editor.bracketPairColorization.enabled": true,
        "editor.guides.bracketPairs":       true,
        "editor.formatOnSave":              true,
        "files.autoSave":                   "afterDelay",
        "files.autoSaveDelay":              1000,

        // ── Python ────────────────────────────────────────────────────────
        "python.defaultInterpreterPath":    "/usr/local/bin/python",
        "python.terminal.activateEnvironment": false,

        // ── Live Server ───────────────────────────────────────────────────
        "liveServer.settings.donotShowInfoMsg":  true,
        "liveServer.settings.donotVerifyTags":   true,

        // ── Roo Code — provider and proxy URL ────────────────────────────
        // API key is entered by student once on first launch (30 seconds)
        // Key to enter: class2025
        "roo-cline.apiProvider":    "anthropic",
        "roo-cline.apiModelId":     "claude-sonnet-4-6",

        // ── Terminal ──────────────────────────────────────────────────────
        "terminal.integrated.defaultProfile.linux": "bash",
        "workbench.panel.defaultLocation": "bottom"
      }
    }
  },

  // Ports that get auto-forwarded (Live Server + common dev servers)
  "forwardPorts": [5500, 8000, 8080, 3000],
  "portsAttributes": {
    "5500": { "label": "Live Server", "onAutoForward": "openBrowser" },
    "8000": { "label": "Dev Server",  "onAutoForward": "notify" }
  }
}
